@startuml
!theme plain
skinparam backgroundColor #F8F9FA

title AI Crop Advisory System - User Activity Flow

start

:Farmer opens web application;

partition "Multi-Step Form" {
  :Select Location\n(12 pre-configured cities);
  
  :Choose Season\n(Kharif/Rabi/Zaid/All Year);
  
  :Enter Budget\n(Presets or Custom);
  
  :Enter Land Size\n(Acres or Hectares);
  
  :Select Soil Type\n(6 options);
  
  :Choose Irrigation Method\n(4 options);
  
  :Submit Form;
}

:Show loading animation;

partition "Backend Processing" {
  fork
    :Fetch weather data\nfrom OpenWeatherMap;
  fork again
    :Process form inputs;
  end fork
  
  :Send to Gemini AI;
  
  if (AI responds successfully?) then (yes)
    :Parse AI recommendations;
  else (no)
    :Use fallback recommendations;
  endif
  
  :Build response with\n3 crop recommendations;
}

:Hide loading animation;

:Display weather summary\nwith 5-day forecast;

:Show 3 crop recommendation cards\nwith animations;

repeat
  :Review crop card\n(Investment, Profit, ROI, Risk);
  
  if (Want more details?) then (yes)
    :Expand card;
    :View cultivation steps;
    :View risk assessment;
    :View detailed financials;
  else (no)
  endif
  
repeat while (Check another crop?) is (yes)
-> no;

:View market insights;

if (Satisfied with recommendations?) then (yes)
  :Make farming decision;
  stop
else (no)
  :Try different parameters;
  -> Multi-Step Form;
endif

@enduml
