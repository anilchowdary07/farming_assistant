@startuml
!theme plain
skinparam backgroundColor #F8F9FA

title AI Crop Advisory System - Deployment Architecture

node "User Device" {
  component [Web Browser] as Browser #90EE90
  component [Mobile Browser] as Mobile #98FB98
}

cloud "CDN / Static Hosting" {
  node "Vercel / Netlify" #E8F4F8 {
    component [React App\n(Build/Dist)] as FrontendDeploy #87CEEB
    component [Static Assets\n(CSS, JS, Images)] as Assets #B0E0E6
  }
}

cloud "Backend Hosting" {
  node "Railway / Render / AWS" #FFF3E0 {
    component [Flask API\nGunicorn Server] as Backend #FF6347
    component [Environment\nVariables] as Env #FFD700
    note right of Env
      GEMINI_API_KEY
      OPENWEATHER_API_KEY
      FLASK_ENV
    end note
  }
}

cloud "External Services" {
  node "OpenWeatherMap" #87CEEB {
    component [Weather API] as WeatherAPI
  }
  
  node "Google Cloud" #FFD700 {
    component [Gemini AI API] as GeminiAPI
  }
}

' Connections
Browser --> FrontendDeploy : HTTPS
Mobile --> FrontendDeploy : HTTPS

FrontendDeploy --> Assets : loads

FrontendDeploy --> Backend : REST API\n(HTTPS)

Backend --> Env : reads config

Backend --> WeatherAPI : API calls
Backend --> GeminiAPI : API calls

' Notes
note bottom of FrontendDeploy
  Build Command: npm run build
  Output: dist/
  Environment: VITE_API_URL
end note

note bottom of Backend
  Start Command: gunicorn app:app
  Port: 5000
  CORS: Enabled for frontend
end note

@enduml
