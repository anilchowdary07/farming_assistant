@startuml
!theme plain
skinparam backgroundColor #F8F9FA
skinparam componentStyle rectangle

title AI Crop Advisory System - Component Architecture

' External Systems
cloud "External APIs" {
  component [OpenWeatherMap API] as OWM #87CEEB
  component [Google Gemini AI] as Gemini #FFD700
}

' Frontend Layer
package "Frontend - React + Vite" #E8F4F8 {
  
  package "UI Components" {
    component [Multi-Step Form] as Form #90EE90
    component [Loading Animation] as Loading #FFA07A
    component [Results Display] as Results #98FB98
    component [Weather Cards] as WeatherUI #87CEEB
    component [Crop Cards] as CropCards #FFD700
    component [Market Insights] as MarketUI #FFA500
  }
  
  package "Form Steps" {
    component [Location Select] as Step1
    component [Season Select] as Step2
    component [Budget & Land] as Step3
    component [Soil & Irrigation] as Step4
  }
  
  component [API Client\n(Axios)] as APIClient #FF6B6B
  component [State Management\n(React Hooks)] as State #9370DB
}

' Backend Layer
package "Backend - Flask + Python" #FFF3E0 {
  
  component [Flask REST API\n/api/recommend] as FlaskAPI #FF6347
  component [CORS Handler] as CORS #FFB6C1
  
  package "Services" {
    component [Weather Service] as WeatherSvc #87CEEB
    component [Gemini AI Service] as GeminiSvc #FFD700
  }
  
  package "Models" {
    component [Pydantic Schemas\nValidation] as Schemas #98D8C8
  }
  
  package "Utils" {
    component [Error Handler] as ErrorHandler #FF6B6B
    component [Logger] as Logger #D3D3D3
  }
}

' Data Flow
Form --> Step1
Form --> Step2
Form --> Step3
Form --> Step4

Step1 --> State
Step2 --> State
Step3 --> State
Step4 --> State

State --> APIClient : submit data

APIClient --> FlaskAPI : POST /api/recommend

FlaskAPI --> CORS : validate origin
FlaskAPI --> Schemas : validate request

Schemas --> WeatherSvc : location data
Schemas --> GeminiSvc : all parameters

WeatherSvc --> OWM : fetch weather\n& forecast
GeminiSvc --> Gemini : AI analysis

WeatherSvc --> FlaskAPI : weather JSON
GeminiSvc --> FlaskAPI : recommendations JSON

FlaskAPI --> ErrorHandler : error handling
FlaskAPI --> Logger : log requests

FlaskAPI --> APIClient : response JSON

APIClient --> State : update state
State --> Loading : show while waiting
State --> Results : show on success

Results --> WeatherUI : weather data
Results --> CropCards : crop recommendations
Results --> MarketUI : market insights

CropCards --> CropCards : expandable details

note right of FlaskAPI
  Endpoints:
  - POST /api/recommend
  - GET /health
  - GET /api/test-weather
end note

note right of GeminiSvc
  Uses structured prompts
  to generate 3 crop
  recommendations with:
  - Investment costs
  - Profit estimates
  - ROI calculations
  - Risk assessment
  - Cultivation steps
end note

note bottom of Schemas
  Validates:
  - Location (lat, lon, name)
  - Season (Kharif/Rabi/Zaid)
  - Budget (numeric)
  - Land size & unit
  - Soil type
  - Irrigation method
end note

@enduml
