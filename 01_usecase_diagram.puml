@startuml
!theme plain
skinparam backgroundColor #F8F9FA
skinparam actorStyle awesome

title AI Crop Advisory System - Use Case Diagram

left to right direction

actor "Farmer" as farmer #90EE90
actor "OpenWeatherMap\nAPI" as weather #87CEEB
actor "Google Gemini\nAI" as gemini #FFD700

rectangle "AI Crop Advisory System" {
  usecase "Enter Location" as UC1
  usecase "Select Season" as UC2
  usecase "Enter Budget &\nLand Details" as UC3
  usecase "Select Soil Type &\nIrrigation" as UC4
  usecase "Get Weather Data" as UC5
  usecase "Get AI Crop\nRecommendations" as UC6
  usecase "View Recommendations" as UC7
  usecase "View Weather Forecast" as UC8
  usecase "View Cultivation Steps" as UC9
  usecase "View Risk Assessment" as UC10
  usecase "View Market Insights" as UC11
  usecase "View Profit Estimates\n& ROI" as UC12
  usecase "Expand Crop Details" as UC13
  usecase "View Investment\nBreakdown" as UC14
}

' Farmer interactions
farmer --> UC1
farmer --> UC2
farmer --> UC3
farmer --> UC4
farmer --> UC7
farmer --> UC8
farmer --> UC9
farmer --> UC10
farmer --> UC11
farmer --> UC12
farmer --> UC13
farmer --> UC14

' System interactions
UC1 ..> UC5 : triggers
UC2 ..> UC6 : triggers
UC3 ..> UC6 : triggers
UC4 ..> UC6 : triggers

UC5 <-- weather : provides
UC6 <-- gemini : provides

UC6 ..> UC7 : includes
UC6 ..> UC12 : includes
UC6 ..> UC14 : includes

UC7 ..> UC9 : extends
UC7 ..> UC10 : extends
UC7 ..> UC11 : extends
UC13 ..> UC9 : reveals
UC13 ..> UC10 : reveals

note right of UC6
  AI analyzes weather, soil,
  budget, and market data to
  recommend top 3 crops
end note

note right of UC7
  Shows crop cards with
  investment, profit range,
  ROI, and risk levels
end note

@enduml
